.ignored/
*.ipa

# Claude Code local settings and agent worktrees
.claude/

# Stray screenshots at repo root (Maestro writes to app/maestro/screenshots/)
/*.png

# Maestro screenshots wherever they land (incl. repo root if run from here)
**/maestro/screenshots/

# Store working files (listing copy, screenshots) — local only.
# Anchored to repo root so it does NOT match app/src/store/ (which EAS would
# then drop from the build, breaking module resolution).
/store/
