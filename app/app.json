{
  "expo": {
    "name": "Diktat",
    "slug": "diktat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "updates": {
