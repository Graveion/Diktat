      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "Diktat uses speech recognition to transcribe your voice into coding instructions.",
        "NSMicrophoneUsageDescription": "Diktat needs microphone access to record your voice instructions.",
        "NSPhotoLibraryUsageDescription": "Diktat only uses the camera to scan pairing QR codes; it does not access your photo library.",
        "NSPhotoLibraryAddUsageDescription": "Diktat only uses the camera to scan pairing QR codes; it does not save anything to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b7b6c69b-e870-4470-9944-daef2f579bf6"
      },
      "supabaseUrl": "https://sxikqegkvbeahtcnoozx.supabase.co",
      "supabasePublishableKey": "sb_publishable_ZiQTn9qGtfJLUyeFwD-F4A_27RpLh4P",
      "relayUrl": "wss://diktat-relay.fly.dev",
      "revenueCatIosKey": "",
      "googleWebClientId": "194173396831-pa3jme56di96crfpojllhb38he832deh.apps.googleusercontent.com",
      "googleIosClientId": "194173396831-4toso43fmm94ej5vivv116oodes336fo.apps.googleusercontent.com"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "RecaptchaInterop", "modular_headers": true }
            ]
          }
        }
      ],
      "expo-font",
      "expo-localization",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Diktat needs microphone access to record your voice instructions.",
          "speechRecognitionPermission": "Diktat uses speech recognition to transcribe your voice into coding instructions."
        }
      ],
      "expo-apple-authentication",
      [
        "expo-camera",
