{
  "expo": {
    "name": "Diktat",
    "slug": "diktat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/b7b6c69b-e870-4470-9944-daef2f579bf6"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.graveion.diktat",
      "backgroundModes": [
        "remote-notification"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "Diktat uses speech recognition to transcribe your voice into coding instructions.",
        "NSMicrophoneUsageDescription": "Diktat needs microphone access to record your voice instructions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b7b6c69b-e870-4470-9944-daef2f579bf6"
      }
    },
    "plugins": [
      "expo-localization",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Diktat needs microphone access to record your voice instructions.",
          "speechRecognitionPermission": "Diktat uses speech recognition to transcribe your voice into coding instructions."
        }
      ]
    ]
  }
}
